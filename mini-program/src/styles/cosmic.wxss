/* 科幻魔法风：深色宇宙底 + 青紫霓虹 + 玻璃拟态（各页 @import） */

.cosmic-page {
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
  padding: 24rpx 24rpx 48rpx;
  overflow-x: hidden;
  background: linear-gradient(168deg, #050810 0%, #0c1224 38%, #140828 72%, #0a1628 100%);
}

/* 柔光星尘层 */
.cosmic-page::before {
  content: "";
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  height: 45vh;
  pointer-events: none;
  background: radial-gradient(
      ellipse 120% 80% at 50% -10%,
      rgba(0, 212, 255, 0.12) 0%,
      transparent 55%
    ),
    radial-gradient(ellipse 90% 60% at 100% 20%, rgba(124, 58, 237, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse 70% 50% at 0% 60%, rgba(236, 72, 153, 0.06) 0%, transparent 45%);
  z-index: 0;
}

.cosmic-inner {
  position: relative;
  z-index: 1;
}

.container {
  padding: 0;
}

/* 标题：微发光 */
.cosmic-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8eeff;
  letter-spacing: 4rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.35), 0 0 40rpx rgba(124, 58, 237, 0.25);
}

.cosmic-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(199, 210, 255, 0.65);
  letter-spacing: 2rpx;
}

/* 玻璃卡片 */
.glass-panel {
  background: rgba(18, 24, 48, 0.55);
  border: 1rpx solid rgba(124, 58, 237, 0.25);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px);
}

/* 分区标题 */
.section-label {
  font-size: 24rpx;
  color: rgba(165, 180, 252, 0.9);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  display: block;
  text-transform: uppercase;
}

.section {
  margin-top: 36rpx;
}

/* 选项行 */
.option-row {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.65);
  border: 1rpx solid rgba(0, 212, 255, 0.15);
  display: flex;
  align-items: center;
}

.option-row radio {
  margin-right: 16rpx;
}

.option-row text {
  font-size: 28rpx;
  color: #e0e7ff;
}

/* 主按钮：霓虹渐变 */
.btn-neon {
  margin-top: 20rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  border-radius: 48rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx !important;
  color: #f0f4ff !important;
  background: linear-gradient(135deg, #00b4d8 0%, #7c3aed 50%, #c026d3 100%) !important;
  border: none !important;
  box-shadow: 0 8rpx 28rpx rgba(124, 58, 237, 0.4), 0 0 40rpx rgba(0, 180, 216, 0.2) !important;
}

.btn-neon::after {
  border: none !important;
}

/* 幽灵按钮 */
.btn-ghost {
  margin-top: 20rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
  font-size: 28rpx !important;
  color: #c4b5fd !important;
  background: rgba(124, 58, 237, 0.12) !important;
  border: 1rpx solid rgba(0, 212, 255, 0.35) !important;
  box-shadow: inset 0 0 24rpx rgba(0, 212, 255, 0.06) !important;
}

.btn-ghost::after {
  border: none !important;
}

/* 危险操作（删除） */
.btn-danger {
  margin-top: 20rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
  font-size: 28rpx !important;
  color: #fecaca !important;
  background: rgba(127, 29, 29, 0.35) !important;
  border: 1rpx solid rgba(248, 113, 113, 0.45) !important;
}

.btn-danger::after {
  border: none !important;
}

/* 解读卡片 */
.oracle-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(17, 24, 39, 0.85) 0%, rgba(30, 27, 75, 0.6) 100%);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  box-shadow: 0 0 24rpx rgba(124, 58, 237, 0.15);
}

.oracle-pos {
  font-size: 24rpx;
  color: #7dd3fc;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.oracle-text {
  font-size: 28rpx;
  color: rgba(238, 242, 255, 0.92);
  line-height: 1.65;
  white-space: pre-wrap;
}

/* 文本域 */
.cosmic-textarea {
  width: 100%;
  min-height: 180rpx;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #e8eeff;
  background: rgba(15, 23, 42, 0.75);
  border: 1rpx solid rgba(124, 58, 237, 0.25);
}

/* 历史列表项 */
.timeline-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.7);
  border: 1rpx solid rgba(168, 85, 247, 0.2);
  border-left: 6rpx solid #00d4ff;
}

.timeline-meta {
  font-size: 22rpx;
  color: rgba(125, 211, 252, 0.75);
  display: block;
  margin-bottom: 12rpx;
}

.timeline-summary {
  font-size: 28rpx;
  color: #e0e7ff;
  white-space: pre-wrap;
  line-height: 1.55;
}

/* 空状态 */
.empty-cosmic {
  margin-top: 48rpx;
  padding: 40rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.4);
  border: 1rpx dashed rgba(124, 58, 237, 0.35);
}

.empty-cosmic-text {
  font-size: 28rpx;
  color: rgba(199, 210, 255, 0.7);
  line-height: 1.7;
}

/* 首页光晕装饰 */
.hero-glow {
  margin-top: 48rpx;
  padding: 40rpx 32rpx 48rpx;
  border-radius: 32rpx;
  text-align: center;
  background: radial-gradient(ellipse 100% 100% at 50% 0%, rgba(124, 58, 237, 0.2), transparent 65%),
    rgba(15, 23, 42, 0.5);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.hero-orbit {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d4ff 0%, #7c3aed 45%, #ec4899 100%);
  opacity: 0.9;
  box-shadow: 0 0 48rpx rgba(0, 212, 255, 0.35), inset 0 0 24rpx rgba(255, 255, 255, 0.15);
  animation: pulse-glow 3s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%,
  100% {
    transform: scale(1);
    opacity: 0.85;
  }
  50% {
    transform: scale(1.06);
    opacity: 1;
  }
}
